# Salin file ini ke /etc/flask-app.env di setiap VM, lalu isi nilainya
# cp .env.example /etc/flask-app.env
# nano /etc/flask-app.env

# MongoDB URI — ganti IP_VM3 dengan IP internal VM-3 (dapat dari tim Database)
# Contoh: mongodb://10.148.0.3:27017/
MONGO_URI=mongodb://IP_VM3:27017/

# JWT Secret — HARUS sama persis di VM-1 dan VM-2 agar token valid di kedua server
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_PANJANG_MIN_32_KARAKTER

# Durasi token JWT dalam detik (default 24 jam)
JWT_EXPIRES=86400
